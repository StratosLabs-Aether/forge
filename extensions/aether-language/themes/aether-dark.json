    { "scope": "string", "settings": { "foreground": "#50d0a0" }},
    { "scope": "constant.numeric", "settings": { "foreground": "#f0c060" }},
    { "scope": "entity.name.function", "settings": { "foreground": "#89b4fa" }},
    { "scope": "entity.name.type", "settings": { "foreground": "#f0c060" }},
    { "scope": "variable", "settings": { "foreground": "#e0e0f0" }},
    { "scope": "support.function", "settings": { "foreground": "#89b4fa" }},
    { "scope": "storage.type", "settings": { "foreground": "#c084fc" }}
