{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aether",
  "scopeName": "source.aether",
  "patterns": [
    {
      "name": "comment.block.aether",
      "begin": "#!\\*",
      "end": "#!\\*"
    },
    {
      "name": "comment.line.number-sign.aether",
      "match": "#!.*$"
    },
    {
      "name": "constant.other.color.aether",
      "match": "#[0-9a-fA-F]{3,8}\\b"
    },
    {
      "name": "string.quoted.double.aether",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.aether",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "keyword.control.flow.aether",
      "match": "\\b(if|otherwise|or|match|case|repeat|until|while|for|in|do|catch|otherwise|lastly|stop|next|reset|break|continue|restart|give|flag|empty)\\b"
    },
    {
      "name": "keyword.operator.logical.aether",
      "match": "\\b(and|not|is|in|true|false|yes|no)\\b"
    },
    {
      "name": "keyword.other.aether",
      "match": "\\b(var|fun|say|get|from|as|is|assert|assert_eq)\\b"
    },
    {
      "name": "storage.type.aether",
      "match": "\\b(string|int|float|boolean|bool|dynamic|empty|list|dict|any)\\b"
    },
    {
      "name": "constant.language.boolean.aether",
      "match": "\\b(true|false|yes|no|empty)\\b"
    },
    {
      "name": "constant.numeric.aether",
      "match": "\\b\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b"
    },
    {
      "name": "support.function.builtin.aether",
      "match": "\\b(len|typeOf|ask|print|append|join|split|replace|keys|values|items|range|parse|format|now|sleep|read|write|exists|remove|copy|sort|map|filter|reduce|each|push|pop|shift|unshift|slice|concat|indexOf|includes|startsWith|endsWith|trim|upper|lower|title)\\b"
    },
    {
      "name": "entity.name.function.definition.aether",
      "match": "(?<=fun\\s)[a-zA-Z_][a-zA-Z0-9_]*"
    },
    {
      "name": "entity.name.function.call.aether",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
    },
    {
      "name": "variable.other.aether",
      "match": "(?<=var\\s)[a-zA-Z_][a-zA-Z0-9_]*"
    },
    {
      "name": "variable.parameter.aether",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*is\\b)"
    },
    {
      "name": "punctuation.definition.tag.aether",
      "match": "[{}()\\[\\],:;]"
    },
    {
      "name": "keyword.operator.arithmetic.aether",
      "match": "[+\\-*/%^]"
    },
    {
      "name": "keyword.operator.comparison.aether",
      "match": "==|!=|<=|>=|<|>"
    }
  ]
}